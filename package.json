{
  "name": "mapa-sinal-br",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "electron-main.mjs",
  "description": "App standalone para mapa ao vivo de ERBs TIM e Vivo no Brasil.",
  "author": "Codex",
  "scripts": {
    "start:web": "node server.mjs",
    "start": "electron .",
    "check": "node --check server.mjs && node --check public/app.js",
    "sync:telecocare": "node scripts/update-telecocare.mjs",
    "dist": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.mapa.sinal.br",
    "productName": "Mapa Sinal BR",
    "electronVersion": "37.2.0",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.mjs",
      "server.mjs",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false,
      "artifactName": "Mapa-Sinal-BR-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "packElevateHelper": false,
      "artifactName": "Mapa-Sinal-BR-Setup-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "37.2.0",
    "electron-builder": "26.8.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "leaflet": "^1.9.4",
    "xlsx": "^0.18.5"
  }
}
